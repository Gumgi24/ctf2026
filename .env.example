# Clé secrète Flask — à changer impérativement en production
SECRET_KEY=change-me-with-a-long-random-string

# Identifiants de l'interface admin (HTTP Basic Auth)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me

# Chemin vers la base SQLite (relatif au répertoire de l'application)
DATABASE_PATH=ctf.db

# Hôte et port d'écoute de l'application
APP_HOST=127.0.0.1
APP_PORT=8000

# Ne jamais passer à true en production
DEBUG=false
